generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                   String                   @id @default(cuid())
  nombre               String
  email                String                   @unique
  password             String
  rol                  Rol                      @default(COLECTOR)
  activo               Boolean                  @default(true)
  creadoEn             DateTime                 @default(now())
  cambiosConfiguracion HistorialConfiguracion[] @relation("HistorialConfiguracionUsuario")
  pagosRegistrados     Pago[]                   @relation("PagoRegistradoPorUsuario")
}

model Estudiante {
  id                      String        @id @default(cuid())
  nombre                  String        @default("")
  nie                     String?       @unique
  grado                   String        @default("")
  seccion                 String        @default("")
  encargado               String?
  telefono                String?
  creadoEn                DateTime      @default(now())
  activo                  Boolean       @default(true)
  alergias                String[]      @default([])
  comportamiento          String[]      @default([])
  descripcion             String?
  embarazo                String?
  embarazoPorQue          String?
  enfermedades            String[]      @default([])
  limitaciones            String[]      @default([])
  problemasAprendizaje    String?
  tipoParto               String?
  turno                   String?       @default("Matutino")
  vacunas                 String[]      @default([])
  nombres                 String?
  primerApellido          String?
  segundoApellido         String?
  lugarNacimiento         String?
  fechaNacimiento         DateTime?
  correo                  String?
  religion                String?
  estadoCivil             String?
  estudioParvularia       Boolean       @default(false)
  repiteGrado             Boolean       @default(false)
  transporte              String?
  distancia               String?
  tallaPantalon           String?
  tallaCamisa             String?
  tallaZapatos            String?
  direccion               String?
  departamento            String?
  municipio               String?
  canton                  String?
  viveCon                 String?
  dependeEconomicamente   String?
  miembrosFamilia         String?
  estudianteTrabaja       Boolean       @default(false)
  tieneHijos              Boolean       @default(false)
  padreProfesion          String?
  padreTelefonoTrabajo    String?
  padreDireccion          String?
  padreDepartamento       String?
  padreMunicipio          String?
  padreCanton             String?
  documentosEntregados    String[]      @default([])
  fotoDataUrl             String?       @db.Text
  comprobantes            Comprobante[]
  pagos                   Pago[]
  talonarios              Talonario[]
}

model Talonario {
  id           String        @id @default(cuid())
  estudianteId String
  anio         Int
  grado        String?
  seccion      String?
  turno        String?
  creadoEn     DateTime      @default(now())
  comprobantes Comprobante[]
  estudiante   Estudiante    @relation(fields: [estudianteId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, anio])
}

model Comprobante {
  id           String      @id @default(cuid())
  talonarioId  String?
  tipo         TipoPago
  mes          String?
  monto        Float
  pagado       Boolean     @default(false)
  fechaPago    DateTime?
  orden        Int         @default(0)
  estudianteId String?
  estudiante   Estudiante? @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  talonario    Talonario?  @relation(fields: [talonarioId], references: [id], onDelete: Cascade)
  pago         Pago?
}

model Pago {
  id                String       @id @default(cuid())
  estudianteId      String
  comprobanteId     String?      @unique
  monto             Float
  tipo              TipoPago
  fecha             DateTime     @default(now())
  registradoPor     String
  notas             String?
  tipoPersonalizado String?
  cantidad          Int?
  comprobante       Comprobante? @relation(fields: [comprobanteId], references: [id])
  estudiante        Estudiante   @relation(fields: [estudianteId], references: [id])
  registrador       Usuario      @relation("PagoRegistradoPorUsuario", fields: [registradoPor], references: [id])

  @@index([fecha])
  @@index([tipo])
  @@index([estudianteId])
  @@index([registradoPor])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model ConfiguracionSistema {
  id                String   @id @default("global")
  logoUrl           String?
  montoMatricula    Float    @default(10)
  montoPapeleria    Float    @default(15)
  montoMensualidad  Float    @default(20)
  montoAlimentacion Float    @default(10)
  montoMora         Float?   @default(0)
  usarMora          Boolean  @default(false)
  actualizadoEn     DateTime @updatedAt
  diaLimitePago     Int      @default(26)
}

model HistorialConfiguracion {
  id            String   @id @default(cuid())
  usuarioId     String
  nombreUsuario String
  fecha         DateTime @default(now())
  campo         String
  valorAnterior String
  valorNuevo    String
  usuario       Usuario  @relation("HistorialConfiguracionUsuario", fields: [usuarioId], references: [id])
}

enum Rol {
  COLECTOR
  MATRICULA
  ADMINISTRATIVO
}

enum TipoPago {
  MATRICULA
  PAPELERIA
  COLEGIATURA
  ALIMENTACION
  OTRO
}
