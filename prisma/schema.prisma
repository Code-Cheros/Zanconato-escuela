// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         String     @id @default(cuid())
  nombre     String
  email      String     @unique
  password   String
  rol        Rol        @default(COLECTOR)
  activo     Boolean    @default(true)
  creadoEn   DateTime   @default(now())
  pagosRegistrados Pago[] @relation("PagoRegistradoPorUsuario")
  cambiosConfiguracion HistorialConfiguracion[] @relation("HistorialConfiguracionUsuario")
}

enum Rol {
  COLECTOR
  MATRICULA
  ADMINISTRATIVO
}

model Estudiante {
  id         String      @id @default(cuid())
  nombre     String
  nie        String      @unique
  grado      String
  seccion    String
  encargado  String?
  telefono   String?
  activo     Boolean     @default(true)
  pagos      Pago[]
  talonarios Talonario[]
  comprobantes Comprobante[]
  creadoEn   DateTime    @default(now())
}

model Talonario {
  id           String        @id @default(cuid())
  estudianteId String
  estudiante   Estudiante    @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  anio         Int
  grado        String?
  seccion      String?
  comprobantes Comprobante[]
  creadoEn     DateTime      @default(now())

  @@unique([estudianteId, anio])
}


model Comprobante {
  id           String     @id @default(cuid())
  talonarioId  String?
  talonario    Talonario? @relation(fields: [talonarioId], references: [id], onDelete: Cascade)
  estudianteId String?
  estudiante   Estudiante? @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  tipo         TipoPago
  mes          String?
  monto        Float
  pagado       Boolean    @default(false)
  fechaPago    DateTime?
  orden        Int        @default(0)
  pago         Pago?
}

model Pago {
  id            String      @id @default(cuid())
  estudianteId  String
  estudiante    Estudiante  @relation(fields: [estudianteId], references: [id])
  comprobanteId String?     @unique
  comprobante   Comprobante? @relation(fields: [comprobanteId], references: [id])
  monto         Float
  tipo          TipoPago
  tipoPersonalizado String?
  cantidad      Int?
  fecha         DateTime    @default(now())
  registradoPor String
  registrador   Usuario     @relation("PagoRegistradoPorUsuario", fields: [registradoPor], references: [id], onDelete: Restrict, onUpdate: Cascade)
  notas         String?

  @@index([fecha])
  @@index([tipo])
  @@index([estudianteId])
  @@index([registradoPor])
}

enum TipoPago {
  MATRICULA
  PAPELERIA
  COLEGIATURA
  ALIMENTACION
  OTRO
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model ConfiguracionSistema {
  id                String   @id @default("global")
  logoUrl           String?
  montoMatricula    Float    @default(10)
  montoPapeleria    Float    @default(15)
  montoMensualidad  Float    @default(20)
  montoAlimentacion Float    @default(10)
  diaLimitePago     Int      @default(26)
  montoMora         Float?   @default(0)
  usarMora          Boolean  @default(false)
  actualizadoEn     DateTime @updatedAt
}

model HistorialConfiguracion {
  id             String   @id @default(cuid())
  usuarioId      String
  usuario        Usuario  @relation("HistorialConfiguracionUsuario", fields: [usuarioId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  nombreUsuario  String
  fecha          DateTime @default(now())
  campo          String   // e.g., 'montoMatricula', 'montoPapeleria', etc.
  valorAnterior  String
  valorNuevo     String
}
